[[ -z "$DATAVIZ_LAMBDA_ARN" ]] && echo "ERROR: DATAVIZ_LAMBDA_ARN is empty" || echo "DATAVIZ_LAMBDA_ARN=$DATAVIZ_LAMBDA_ARN"

